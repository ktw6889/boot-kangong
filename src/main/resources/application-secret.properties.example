# application-secret.properties 로 복사 후 실제 값 입력 (git에는 포함되지 않음)
spring.datasource.username=YOUR_DB_USER
spring.datasource.password=YOUR_DB_PASSWORD

stock.selenium.driver-path=C:\\path\\to\\chromedriver.exe

# ECOS(한국은행): https://ecos.bok.or.kr/api/
macro.ecos.api-key=YOUR_ECOS_API_KEY
# FRED(미국 연준): https://fred.stlouisfed.org/docs/api/api_key.html
macro.fred.api-key=YOUR_FRED_API_KEY
